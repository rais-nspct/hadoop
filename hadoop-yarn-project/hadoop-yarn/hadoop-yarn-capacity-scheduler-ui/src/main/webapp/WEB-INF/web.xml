<web-app version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee">
  <display-name>YARN Capacity Scheduler UI</display-name>

  <!-- Default welcome files -->
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>

  <!-- Enable SPA routing - forward all non-file requests to index.html -->
  <error-page>
    <error-code>404</error-code>
    <location>/index.html</location>
  </error-page>
</web-app>
